# ═══════════════════════════════════════════════════════════════════════════
# Wildbox Security Suite - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
#
# 🚨 CRITICAL SECURITY WARNING:
# -------------------------------
# - NEVER commit the actual .env file to version control
# - Generate secure random values for ALL secrets below
# - Change ALL default passwords immediately
# - This file contains ONLY templates - the actual .env must have real values
#
# 📋 SETUP INSTRUCTIONS:
# ----------------------
# 1. Copy this file:      cp .env.template .env
# 2. Generate secrets:    make generate-secrets
#    (or manually with:   openssl rand -hex 32)
# 3. Verify security:     make validate-secrets
# 4. Start services:      docker-compose up -d
#
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 1: REQUIRED SECRETS (MUST BE CHANGED)
# ═══════════════════════════════════════════════════════════════════════════
# These secrets MUST be filled with secure random values.
# The startup validation script will reject insecure defaults.

# JWT Secret Key - Used for signing authentication tokens
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Database Password - PostgreSQL superuser password
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Gateway Internal Secret - Used for gateway <-> service communication
# Generate with: openssl rand -hex 32
GATEWAY_INTERNAL_SECRET=

# API Key - Master API key for inter-service communication
# Format: wsk_<prefix>.<hex>
# Generate with: echo "wsk_prod.$(openssl rand -hex 32)"
API_KEY=

# Initial Admin Password - First admin user password (change after first login)
# Generate with: openssl rand -base64 24
INITIAL_ADMIN_PASSWORD=

# NextAuth Secret - Required for dashboard authentication sessions
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# N8N Credentials - Required if using workflow automation
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 3: INITIAL ADMIN ACCOUNT
# ═══════════════════════════════════════════════════════════════════════════

# Initial admin email (can be changed, but must be valid email format)
INITIAL_ADMIN_EMAIL=admin@wildbox.security

# Flag to create initial admin on first startup
CREATE_INITIAL_ADMIN=true

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 4: ENVIRONMENT CONFIGURATION (Safe defaults provided)
# ═══════════════════════════════════════════════════════════════════════════

# Environment type (development, staging, production)
ENVIRONMENT=development

# Enable debug mode (NEVER true in production)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 5: DATABASE URLS (REQUIRED - Must be explicitly set)
# ═══════════════════════════════════════════════════════════════════════════
# These are required after docker-compose.yml security hardening.
# Construct using your POSTGRES_PASSWORD from SECTION 1.

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/identity
DATA_DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/data
GUARDIAN_DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/guardian
RESPONDER_DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/responder

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 6: REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Redis connection URL (logical database separation via DB number)
REDIS_URL=redis://wildbox-redis:6379/0

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 7: CORS & FRONTEND
# ═══════════════════════════════════════════════════════════════════════════

# Allowed CORS origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend configuration
NEXT_PUBLIC_USE_GATEWAY=true
NEXT_PUBLIC_GATEWAY_URL=http://localhost

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 8: N8N AUTOMATION (Optional - Additional Configuration)
# ═══════════════════════════════════════════════════════════════════════════

# N8N encryption key
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 9: GRAFANA (Optional - for observability)
# ═══════════════════════════════════════════════════════════════════════════

# Grafana admin password
# Generate with: openssl rand -base64 16
GRAFANA_ADMIN_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 10: RATE LIMITING (Optional - defaults are reasonable)
# ═══════════════════════════════════════════════════════════════════════════

# Rate limit: requests per window
RATE_LIMIT_REQUESTS=500

# Rate limit: window in seconds
RATE_LIMIT_WINDOW=60

# ═══════════════════════════════════════════════════════════════════════════
# SECTION 11: AI/LLM CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Claude (Anthropic) API key for the AI agents service.
# Leave blank to disable AI threat analysis — the service starts without it.
# Get a key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model to use for analysis.
# ANTHROPIC_MODEL=claude-opus-4-8

# ═══════════════════════════════════════════════════════════════════════════
# VALIDATION CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
# Before starting services, ensure:
# [ ] All secrets in SECTION 1 are filled with random values
# [ ] No value contains "CHANGE", "default", "admin", "password", or "test-"
# [ ] All secrets are minimum 16 characters
# [ ] .env file is in .gitignore (never committed)
# [ ] Run: make validate-secrets (should pass)
#
# If validation fails, regenerate: make generate-secrets
# ═══════════════════════════════════════════════════════════════════════════
